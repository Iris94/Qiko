{
  "manifest_version": 3,
  "name": "Qiko",
  "version": "1.0.0",
  "description": "Send messages and URLs to your friends directly from your browser.",
  "author": "Mirza Iris - neuro94",
  "homepage_url": "https://mirza-iris.dev",
  "icons": {
    "16": "icons/logo-16.png",
    "32": "icons/logo-32.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/logo-16.png",
      "32": "icons/logo-32.png",
      "48": "icons/logo-48.png",
      "128": "icons/logo-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "identity",
    "identity.email",
    "notifications",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.firebasedatabase.app/*",
    "https://*.europe-west1.firebasedatabase.app/*",
    "https://*.googleapis.com/*",
    "https://*.peerjs.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}