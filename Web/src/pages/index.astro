<script>
  function initForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    if (!form) return;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const originalText = btn.textContent || '';

      btn.textContent = 'Transmitting...';
      btn.disabled = true;
      btn.style.opacity = '0.7';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();

        if (res.ok) {
          btn.textContent = 'Transmission Success ✓';
          btn.style.backgroundColor = 'var(--success)';
          btn.style.color = '#2e3440';
          form.reset();
          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.backgroundColor = '';
            btn.style.color = '';
          }, 4000);
        } else {
          alert('Error: ' + data.message);
          btn.textContent = originalText;
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      } catch {
        alert('Terminal error. Please try again.');
        btn.textContent = originalText;
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    });
  }

  // Setup form submission listener
  document.addEventListener('DOMContentLoaded', initForm);
  // Also run if Astro re-loads page content
  document.addEventListener('astro:page-load', initForm);
</script>
