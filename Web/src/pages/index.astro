    border-bottom: 1px solid rgba(94, 129, 172, 0.12) !important;
  }
  .mock-logo {
    width: 20px;
    height: 20px;
  }
  .mock-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text);
  }
  .mock-status {
    margin-left: auto;
