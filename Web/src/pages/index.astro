---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="landing-page-wrapper" style="position: relative; overflow: hidden; min-height: 100vh; width: 100%;">
    <!-- Background Glows -->
    <div style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; overflow: hidden; pointer-events: none; z-index: -1;">
      <div class="aurora-glow-top"></div>
      <div class="aurora-glow-bottom"></div>
    </div>

    <!-- ===== HEADER ===== -->
    <header class="header">
      <div class="container nav-container">
      <a href="#" class="brand">
        <img src="/logo.png" alt="Qiko" class="logo-img" />
        <span class="font-display brand-name">Qiko</span>
      </a>

      <div class="nav-links">
        <a href="#features" class="nav-link font-display">Features</a>
        <a href="#security" class="nav-link font-display">Security</a>
        <a href="#faq" class="nav-link font-display">FAQ</a>
        <a href="#contact" class="nav-link font-display">Feedback</a>
      </div>

      <div class="nav-actions">
        <button id="theme-toggle" class="btn-toggle" title="Toggle theme">
          <span id="theme-icon" class="material-symbols-outlined">dark_mode</span>
        </button>
        <a href="https://chromewebstore.google.com" target="_blank" rel="noopener" class="btn btn-primary btn-sm">
          Get Extension
        </a>
      </div>
    </div>
  </header>

  <!-- ===== MAIN CONTENT ===== -->
  <main>
    <!-- HERO SECTION -->
    <section class="section hero hero-gradient">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="badge">
            <span class="pulse-dot"></span>
            Chrome Extension — Live Now
          </div>

          <h1 class="font-display hero-title">
            Pure Privacy.<br/>
            <span class="text-primary">Zero Friction.</span>
          </h1>

          <p class="hero-desc">
            Secure peer-to-peer messaging. Use this browser to chat instantly, or download our Chrome extension to stay connected in the flow. No servers, no footprints, no accounts.
          </p>

          <div class="hero-actions">
            <a href="/chat" class="btn btn-primary">
              Browser Chat
            </a>
            <a href="https://chromewebstore.google.com" target="_blank" rel="noopener" class="btn btn-outline">
              <span class="material-symbols-outlined" style="margin-right: 4px;">extension</span>
              Get the Extension
            </a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="glow-bg"></div>
          <img src="/logo.png" alt="Qiko Logo" class="hero-logo-img" />
        </div>
      </div>
    </section>

    <!-- FEATURES SECTION -->
    <section id="features" class="section features-sec">
      <div class="container">
        <div class="section-header">
          <div class="header-left">
            <h2 class="font-display section-title">Architected for Anonymity</h2>
            <p class="section-subtitle">
              We've stripped away everything between you and your conversations. No data collection, no storage, no compromises.
            </p>
          </div>
          <span class="header-right font-display text-primary">The Core Pillars</span>
        </div>

        <div class="features-grid">
          <!-- Large Card: Stay in Flow -->
          <div class="card card-pad feature-card-lg flow-card">
            <div class="card-copy">
              <div class="card-badge">Extension Integration</div>
              <h3 class="font-display card-title">Stay in Your Flow</h3>
              <p class="card-desc">
                Forget heavy desktop apps or extra browser tabs. Qiko lives as a Chrome extension — click the icon, share your ID, and start a private session in seconds. No signups, no onboarding, zero friction.
              </p>
            </div>
            <div class="flow-visual-mockup">
              <div class="mock-popup">
                <div class="mock-header">
                  <img src="/logo.png" alt="Qiko" class="mock-logo" />
                  <span class="mock-title font-display">Qiko P2P</span>
                  <div class="mock-status"><span class="pulse-dot-green"></span>Active</div>
                </div>
                <div class="mock-chat">
                  <div class="mock-msg sent">Hey, did you review the code?</div>
                  <div class="mock-msg received">Yep, peer connection is fully encrypted.</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Small Card: No Signups -->
          <div class="card card-pad feature-card-sm anonymity-card">
            <div>
              <div class="icon-chip bg-primary-light text-primary">
                <span class="material-symbols-outlined text-3xl">visibility_off</span>
              </div>
              <h3 class="font-display card-title-sm">No Signups</h3>
              <p class="card-desc-sm">
                No email, no registration, no passwords. Start instantly as a guest or use your Qiko ID to chat without leaving any footprint.
              </p>
            </div>
            <div class="anonymity-visual">
              <div class="anon-circles">
                <div class="anon-circle outer"></div>
                <div class="anon-circle middle"></div>
                <div class="anon-circle inner"><span class="material-symbols-outlined">fingerprint</span></div>
              </div>
            </div>
          </div>

          <!-- Small Card: Direct Connection -->
          <div class="card card-pad feature-card-sm p2p-card">
            <div>
              <div class="icon-chip bg-sec-light text-sec">
                <span class="material-symbols-outlined text-3xl">terminal_lock</span>
              </div>
              <h3 class="font-display card-title-sm">Direct Connection</h3>
              <p class="card-desc-sm">
                Messages flow directly browser-to-browser. Your chats never pass through a central database or server.
              </p>
            </div>
            <div class="p2p-visual">
              <div class="p2p-node source"><span class="material-symbols-outlined">laptop_mac</span></div>
              <div class="p2p-line-wrapper">
                <div class="p2p-line"></div>
                <span class="material-symbols-outlined lock-icon">lock</span>
              </div>
              <div class="p2p-node target"><span class="material-symbols-outlined">phone_iphone</span></div>
            </div>
          </div>

          <!-- Stat Box: 0% Server Storage -->
          <div class="card card-pad feature-card-stat-box">
            <div class="stat-header">
              <span class="material-symbols-outlined stat-icon-top">cloud_off</span>
              <span class="stat-badge red">Ephemeral</span>
            </div>
            <div class="stat-value-large font-display">0%</div>
            <h4 class="font-display stat-title">Server Storage</h4>
            <p class="stat-text">
              Your conversations are temporary and stored only in your active browser memory. Close the tab, and the chat is gone forever.
            </p>
            <div class="stat-bg-decoration">
              <svg viewBox="0 0 100 100" class="stat-ring-svg">
                <circle cx="50" cy="50" r="40" stroke="rgba(255,255,255,0.03)" stroke-width="8" fill="transparent"/>
                <circle cx="50" cy="50" r="40" stroke="var(--primary)" stroke-dasharray="251.2" stroke-dashoffset="0" stroke-width="8" fill="transparent" class="glow-ring"/>
              </svg>
            </div>
          </div>

          <!-- Stat Box: Private Link -->
          <div class="card card-pad feature-card-stat-box">
            <div class="stat-header">
              <span class="material-symbols-outlined stat-icon-top">enhanced_encryption</span>
              <span class="stat-badge green">Direct Link</span>
            </div>
            <div class="stat-value-large font-display">Secure</div>
            <h4 class="font-display stat-title">Private Channels</h4>
            <p class="stat-text">
              Simple direct connection channels ensure that nobody can read your messages except you and the person on the other end.
            </p>
            <div class="stat-bg-decoration lock-decor">
              <span class="material-symbols-outlined">security</span>
            </div>
          </div>

          <!-- Stat Box: Instant Matching -->
          <div class="card card-pad feature-card-stat-box-wide">
            <div class="stat-wide-content">
              <div class="stat-header">
                <span class="material-symbols-outlined stat-icon-top text-sec">bolt</span>
                <span class="stat-badge blue">Fast Connect</span>
              </div>
              <div class="stat-value-large font-display text-glow-sec">Instant</div>
              <h4 class="font-display stat-title">Peer Connection</h4>
              <p class="stat-text">
                Connect in seconds. Just share your generated link or Qiko ID with a peer and begin chatting instantly without delays.
              </p>
            </div>
            <div class="stat-wide-visual">
              <div class="pulse-container">
                <div class="pulse-wave wave-1"></div>
                <div class="pulse-wave wave-2"></div>
                <div class="pulse-center">
                  <span class="material-symbols-outlined">sensors</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Stat Box: Clean Code -->
          <div class="card card-pad feature-card-stat-box-wide">
            <div class="stat-wide-content">
              <div class="stat-header">
                <span class="material-symbols-outlined stat-icon-top text-tert">code</span>
                <span class="stat-badge orange">No Trackers</span>
              </div>
              <div class="stat-value-large font-display text-glow-tert">Clean</div>
              <h4 class="font-display stat-title">Simple Open Web</h4>
              <p class="stat-text">
                Built with standard browser features. Zero tracking cookies, zero hidden scripts, and no background profiling.
              </p>
            </div>
            <div class="stat-wide-visual">
              <div class="node-graph">
                <div class="node n-center"></div>
                <div class="node n-1"></div>
                <div class="node n-2"></div>
                <div class="node n-3"></div>
                <div class="node-line nl-1"></div>
                <div class="node-line nl-2"></div>
                <div class="node-line nl-3"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECURITY / TECHNICAL SECTION -->
    <section id="security" class="section security-sec">
      <div class="container security-grid">
        <div class="security-copy">
          <span class="pre-title font-display text-primary">Cryptography First</span>
          <h2 class="font-display section-title leading-tight">Clinical Security.<br/>Modern Interface.</h2>
          <p class="section-desc">
            Built on a Nord-inspired design philosophy: clean, precise, and distraction-free. High-security tools should feel like the future, not a legacy terminal.
          </p>
          <ul class="benefits-list">
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Firebase Realtime DB utilized solely for signaling
            </li>
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Identity metadata stored in secure local extension memory
            </li>
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Qiko IDs are ephemeral — delete anytime with zero residues
            </li>
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Strict limit of 5 active connections to minimize footprint
            </li>
          </ul>
        </div>

        <div class="security-mockup">
          <div class="terminal terminal-shadow">
            <div class="terminal-header">
              <div class="window-controls">
                <span class="dot dot-close"></span>
                <span class="dot dot-minimize"></span>
                <span class="dot dot-expand"></span>
              </div>
              <span class="terminal-title">
                <span class="material-symbols-outlined">lock</span>
                secure-p2p-channel.qiko
              </span>
            </div>
            
            <div class="terminal-body">
              <div class="log-info">// Establishing P2P link...</div>
              
              <div class="message-row sent">
                <div class="message-bubble bubble-sent">
                  Initiating session. Encryption key verified.
                </div>
                <span class="timestamp">10:24 AM • Delivered</span>
              </div>

              <div class="message-row received">
                <div class="message-bubble bubble-received">
                  Connection stable. Peer hash: <span class="hash text-accent">#92x-K821-Q0</span>
                </div>
                <span class="timestamp">10:25 AM</span>
              </div>

              <div class="status-divider">
                <span class="status-chip">
                  <span class="material-symbols-outlined status-icon">verified_user</span>
                  Verified P2P Channel Active
                </span>
              </div>
            </div>

            <div class="terminal-input">
              <div class="input-placeholder">Type a secure message...</div>
              <button class="btn-send"><span class="material-symbols-outlined">send</span></button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section id="faq" class="section faq-sec">
      <div class="container faq-container">
        <h2 class="font-display section-title text-center">Common Questions</h2>
        
        <div class="faq-list">
          <details class="card faq-item">
            <summary class="faq-summary">
              Do I need to create an account?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              No. You can start as a guest immediately. Optionally add an email to create a persistent Qiko ID you can use across multiple devices.
            </div>
          </details>

          <details class="card faq-item">
            <summary class="faq-summary">
              Where are my messages stored?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              Messages are stored only in your local browser extension storage (chrome.storage.local). Your conversation history never touches our servers.
            </div>
          </details>

          <details class="card faq-item">
            <summary class="faq-summary">
              Who can message me?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              Only people you've added as a contact and who have your Qiko ID. You can have up to 5 connections active at any given time.
            </div>
          </details>

          <details class="card faq-item">
            <summary class="faq-summary">
              What is a Qiko ID?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              A short unique identifier (e.g. qx-abc123) generated when you set up the extension. Share it with someone you trust — they add it as a contact and you can start messaging.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- CONTACT / FEEDBACK SECTION -->
    <section id="contact" class="section contact-sec">
      <div class="container faq-container">
        <h2 class="font-display section-title text-center">Give Suggestions & Comments</h2>
        <p class="section-subtitle text-center" style="margin-bottom: 32px; max-width: 600px; margin-left: auto; margin-right: auto;">
          Have ideas, found a bug, or want to suggest new features? Send a secure transmission directly to the developer.
        </p>

        <div class="card card-pad contact-card">
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="contact-form">
            <input type="hidden" name="access_key" value="186c8161-07f7-4f99-9b38-ecef428bc717">
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" required class="form-input" placeholder="Your Name" />
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" required class="form-input" placeholder="your.email@example.com" />
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" required rows="4" class="form-input form-textarea" placeholder="Write your suggestions or comments here..."></textarea>
            </div>

            <button type="submit" id="submit-btn" class="btn btn-primary btn-submit">
              Send Feedback
            </button>
          </form>
        </div>
      </div>
    </section>

  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="container footer-container">
      <div class="footer-left">
        <img src="/logo.png" alt="Qiko" class="footer-logo" />
        <span class="font-display footer-brand">Qiko</span>
        <span class="footer-tagline">— Zero Friction P2P Chat</span>
      </div>
      <div class="footer-right">
        Chrome Extension · Built with ❤️ · No servers harmed
      </div>
    </div>
  </footer>
</div>
</Layout>

<style is:global>
  /* ===== CSS STYLES FOR LANDING PAGE ===== */
  
  /* Ambient Background Glows */
  .aurora-glow-top {
    position: absolute;
    top: -150px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(136, 192, 208, 0.15) 0%, rgba(94, 129, 172, 0.05) 50%, transparent 100%);
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    pointer-events: none;
  }
  .aurora-glow-bottom {
    position: absolute;
    bottom: 200px;
    left: -150px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(143, 188, 187, 0.12) 0%, rgba(94, 129, 172, 0.04) 50%, transparent 100%);
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    pointer-events: none;
  }
  [data-theme="light"] .aurora-glow-top {
    background: radial-gradient(circle, rgba(94, 129, 172, 0.08) 0%, rgba(136, 192, 208, 0.03) 50%, transparent 100%);
  }
  [data-theme="light"] .aurora-glow-bottom {
    background: radial-gradient(circle, rgba(94, 129, 172, 0.06) 0%, rgba(143, 188, 187, 0.02) 50%, transparent 100%);
  }

  .features-sec, .faq-sec, .contact-sec, .hero {
    background-color: transparent !important;
    background: transparent !important;
  }

  /* Header */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    width: 100%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background-color: rgba(43, 48, 59, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: background-color var(--transition), border-color var(--transition);
  }
  [data-theme="light"] .header {
    border-bottom: 1px solid rgba(94, 129, 172, 0.15);
    background-color: #ffffff;
  }
  .nav-container {
    display: flex;
    justify-content: justify;
    justify-content: space-between;
    align-items: center;
    height: 72px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .logo-img {
    height: 36px;
    width: 36px;
    object-fit: contain;
  }
  .brand-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.5px;
  }
  .nav-links {
    display: flex;
    gap: 40px;
    align-items: center;
  }
  .nav-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--muted);
    transition: color var(--transition);
  }
  .nav-link:hover {
    color: var(--primary);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .header .btn-primary.btn-sm {
    padding: 6px 14px;
    font-size: 0.8rem;
    border-radius: var(--radius-sm);
  }
  .btn-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    color: var(--primary);
    transition: background var(--transition);
  }
  .btn-toggle:hover {
    background: var(--bg-alt);
  }

  /* Hero Section */
  .hero {
    padding-top: clamp(6.5rem, 13vw, 11rem);
    padding-bottom: clamp(4rem, 10vw, 9rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: center;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
    background-color: color-mix(in srgb, var(--primary) 8%, transparent);
    color: var(--primary);
    margin-bottom: 24px;
  }
  .hero-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -2px;
    margin-bottom: 24px;
    color: var(--text);
  }
  .text-primary {
    color: var(--primary);
  }
  .hero-desc {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 520px;
    margin-bottom: 32px;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .glow-bg {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.15;
    background-color: var(--primary);
  }
  .hero-logo-img {
    position: relative;
    width: 240px;
    height: 240px;
    object-fit: contain;
    filter: drop-shadow(0 12px 36px rgba(var(--primary-rgb), 0.2));
    transition: transform var(--transition);
  }
  .hero-visual:hover .hero-logo-img {
    transform: scale(1.05);
  }
  .web-chat-section {
    margin-bottom: 20px;
  }
  .web-chat-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.85;
  }
  .extension-action {
    margin-top: 16px;
  }
  .btn-extension {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary);
    transition: opacity var(--transition);
  }
  .btn-extension:hover {
    opacity: 0.8;
  }
  .btn-extension .material-symbols-outlined {
    font-size: 1.125rem;
  }

  /* Frosted Glass Bento Cards */
  .card {
    background: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-radius: 24px !important;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1) !important;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease !important;
  }
  .card:hover {
    transform: translateY(-4px) !important;
    border-color: rgba(136, 192, 208, 0.35) !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2) !important;
  }
  
  [data-theme="light"] .card {
    background: #ffffff !important;
    border: 1px solid rgba(94, 129, 172, 0.12) !important;
    box-shadow: 0 10px 30px rgba(94, 129, 172, 0.04) !important;
  }
  [data-theme="light"] .card:hover {
    border-color: rgba(94, 129, 172, 0.25) !important;
    box-shadow: 0 20px 40px rgba(94, 129, 172, 0.08) !important;
  }

  /* Stats Grid Overrides */
  .feature-card-stats {
    background: rgba(255, 255, 255, 0.02) !important;
  }
  [data-theme="light"] .feature-card-stats {
    background: rgba(255, 255, 255, 0.45) !important;
  }
  .stat-number {
    font-size: 2.25rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Translucent Form Inputs */
  .form-input {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 12px 16px;
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    border-radius: 12px;
    background-color: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    color: var(--text) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.3s ease !important;
  }
  [data-theme="light"] .form-input {
    background-color: #ffffff !important;
    border: 1px solid rgba(94, 129, 172, 0.2) !important;
    color: #2e3440 !important;
  }
  .form-input:focus {
    border-color: var(--primary) !important;
    background-color: rgba(255, 255, 255, 0.05) !important;
    box-shadow: 0 0 16px rgba(136, 192, 208, 0.25) !important;
  }
  [data-theme="light"] .form-input:focus {
    background-color: #ffffff !important;
    border-color: var(--primary) !important;
    box-shadow: 0 0 16px rgba(94, 129, 172, 0.15) !important;
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Premium Buttons */
  .btn-primary {
    background: var(--btn-primary-bg) !important;
    color: var(--btn-primary-text) !important;
    border-radius: 12px !important;
    box-shadow: 0 4px 14px rgba(var(--primary-rgb), 0.25) !important;
    border: none !important;
  }
  .btn-primary:hover {
    filter: brightness(1.1) !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 20px rgba(var(--primary-rgb), 0.35) !important;
  }
  .btn-outline {
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
    color: var(--text) !important;
    background: rgba(255, 255, 255, 0.01) !important;
    border-radius: 12px !important;
    backdrop-filter: blur(8px);
  }
  [data-theme="light"] .btn-outline {
    border: 1px solid rgba(94, 129, 172, 0.3) !important;
    background: rgba(255, 255, 255, 0.2) !important;
  }
  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.05) !important;
    border-color: var(--primary) !important;
    transform: translateY(-2px) !important;
  }

  /* Features Section */
  .features-sec {
    background-color: transparent !important;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 24px;
  }
  .header-left {
    max-width: 600px;
  }
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 12px;
    color: var(--text);
  }
  .section-subtitle {
    font-size: 1.125rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .header-right {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 24px;
  }
  .feature-card-lg {
    grid-column: span 8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .card-copy {
    flex: 1;
  }
  .bg-primary-light {
    background-color: color-mix(in srgb, var(--primary) 12%, transparent);
  }
  .card-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
  }
  .card-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .card-art {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--primary) 6%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .art-icon {
    font-size: 5rem;
    color: var(--primary);
    opacity: 0.35;
  }

  .feature-card-sm {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
  }
  .bg-sec-light {
    background-color: color-mix(in srgb, var(--secondary) 12%, transparent);
  }
  .text-sec {
    color: var(--secondary);
  }
  .card-title-sm {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }
  .card-desc-sm {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .bg-tert-light {
    background-color: color-mix(in srgb, var(--tertiary) 12%, transparent);
  }
  .text-tert {
    color: var(--tertiary);
  }

  .feature-card-stats {
    grid-column: span 8;
    background: linear-gradient(135deg, var(--surface), color-mix(in srgb, var(--bg-alt) 70%, transparent));
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    width: 100%;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat-number {
    font-size: 2rem;
    font-weight: 800;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
  }

  /* Technical Section */
  .security-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 64px;
    align-items: center;
  }
  .pre-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    display: block;
  }
  .section-desc {
    font-size: 1.125rem;
    color: var(--muted);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .check-icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .check-icon .material-symbols-outlined {
    font-size: 0.875rem;
    font-weight: 800;
  }

  /* Mockup Terminal */
  .terminal {
    background-color: rgba(43, 48, 59, 0.55) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-radius: 16px !important;
    overflow: hidden;
    font-family: monospace;
    font-size: 0.8125rem;
    color: #e5e9f0;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25) !important;
  }
  [data-theme="light"] .terminal {
    background-color: #ffffff !important;
    border: 1px solid rgba(94, 129, 172, 0.15) !important;
    box-shadow: 0 20px 50px rgba(94, 129, 172, 0.08) !important;
    color: #2e3440 !important;
  }
  .terminal-header {
    background-color: rgba(255, 255, 255, 0.01) !important;
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
  }
  [data-theme="light"] .terminal-header {
    background-color: rgba(255, 255, 255, 0.5) !important;
    border-bottom: 1px solid rgba(94, 129, 172, 0.15) !important;
  }
  .window-controls {
    display: flex;
    gap: 6px;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-close { background-color: #bf616a; }
  .dot-minimize { background-color: #ebcb8b; }
  .dot-expand { background-color: #a3be8c; }
  .terminal-title {
    font-size: 0.75rem;
    color: #8190a6;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  [data-theme="light"] .terminal-title {
    color: #4c566a !important;
  }
  .terminal-title .material-symbols-outlined {
    font-size: 0.875rem;
  }
  .terminal-body {
    padding: 24px;
    min-height: 260px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .log-info {
    color: #8190a6;
  }
  [data-theme="light"] .log-info {
    color: #9eb0c8;
  }
  .message-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .message-row.sent {
    align-items: flex-end;
  }
  .message-row.received {
    align-items: flex-start;
  }
  .message-bubble {
    padding: 12px 16px;
    border-radius: var(--radius-md);
    max-width: 80%;
  }
  .bubble-sent {
    background-color: color-mix(in srgb, var(--primary) 25%, transparent);
    color: #88c0d0;
    border: 1px solid color-mix(in srgb, var(--primary) 35%, transparent);
    border-top-right-radius: 0;
  }
  [data-theme="light"] .bubble-sent {
    background-color: var(--primary) !important;
    color: #ffffff !important;
    border: none !important;
  }
  .bubble-received {
    background-color: rgba(255, 255, 255, 0.05);
    color: #d8dee9;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top-left-radius: 0;
  }
  [data-theme="light"] .bubble-received {
    background-color: rgba(94, 129, 172, 0.08) !important;
    border: 1px solid rgba(94, 129, 172, 0.15) !important;
    color: #2e3440 !important;
  }
  .text-accent {
    color: #88c0d0;
  }
  [data-theme="light"] .text-accent {
    color: var(--primary);
  }
  .timestamp {
    font-size: 0.6875rem;
    color: #8190a6;
  }
  [data-theme="light"] .timestamp {
    color: #9eb0c8;
  }
  .status-divider {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 16px;
    display: flex;
    justify-content: center;
  }
  [data-theme="light"] .status-divider {
    border-top: 1px solid rgba(94, 129, 172, 0.15);
  }
  [data-theme="light"] .status-chip {
    background-color: rgba(46, 125, 50, 0.1) !important;
    border: 1px solid rgba(46, 125, 50, 0.2) !important;
    color: #2e7d32 !important;
  }
  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    background-color: rgba(163, 190, 140, 0.1);
    border: 1px solid rgba(163, 190, 140, 0.25);
    color: #a3be8c;
  }
  .status-icon {
    font-size: 0.8125rem;
  }
  .terminal-input {
    background-color: rgba(255, 255, 255, 0.01) !important;
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
  }
  [data-theme="light"] .terminal-input {
    background-color: rgba(255, 255, 255, 0.5) !important;
    border-top: 1px solid rgba(94, 129, 172, 0.15) !important;
  }
  .input-placeholder {
    color: #8190a6;
    font-style: italic;
  }
  [data-theme="light"] .input-placeholder {
    color: #9eb0c8;
  }
  .btn-send {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background-color: var(--primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .btn-send .material-symbols-outlined {
    font-size: 0.875rem;
  }

  /* FAQ Section */
  .faq-sec {
    background-color: transparent !important;
  }
  .faq-container {
    max-width: 760px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 48px;
  }
  .faq-item {
    border-radius: var(--radius-md) !important;
    overflow: hidden;
    cursor: pointer;
  }
  .faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 28px !important;
    font-weight: 700;
    font-size: 0.95rem;
    user-select: none;
    color: var(--text);
  }
  .faq-chevron {
    color: var(--primary);
    transition: transform var(--transition);
  }
  .faq-content {
    padding: 0 28px 24px 28px !important;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Footer */
  .footer {
    width: 100%;
    border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
    background-color: transparent !important;
    padding: 32px 0;
    transition: background var(--transition), border-color var(--transition);
  }
  [data-theme="light"] .footer {
    border-top: 1px solid rgba(94, 129, 172, 0.15) !important;
  }
  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer-logo {
    height: 24px;
    width: 24px;
    object-fit: contain;
  }
  .footer-brand {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--primary);
  }
  .footer-tagline {
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.7;
  }
  .footer-right {
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.75;
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-visual {
      display: none;
    }
    .features-grid {
      display: flex;
      flex-direction: column;
    }
    .feature-card-lg {
      flex-direction: column;
      text-align: center;
    }
    .card-art {
      margin-top: 16px;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .security-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .nav-links {
      display: none;
    }
    .card-pad {
      padding: 1.5rem;
    }
  }

  @media (max-width: 576px) {
    .nav-container {
      padding: 0 16px;
    }
    .brand-name {
      display: none;
    }
    .nav-actions {
      gap: 8px;
    }
    .brand {
      gap: 4px;
    }
    .stats-grid {
      grid-template-columns: 1fr;
    }
    .hero-actions {
      flex-direction: column;
      width: 100%;
    }
    .hero-actions .btn {
      width: 100%;
    }
    .btn-submit {
      width: 100%;
      align-self: stretch;
    }
  }

  /* Contact Form Styles */
  .contact-sec {
    background-color: var(--bg);
    padding-bottom: 120px;
  }
  .contact-card {
    max-width: 580px;
    margin: 0 auto;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: stretch;
    width: 100%;
  }
  .form-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text);
    text-align: left;
  }
  .btn-submit {
    align-self: flex-start;
    padding: 10px 24px;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  /* Redesigned Bento Grid Visual Styles */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 28px;
    margin-top: 48px;
  }
  
  .flow-card {
    grid-column: span 8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    position: relative;
    overflow: hidden;
  }
  .card-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(136, 192, 208, 0.1);
    color: var(--secondary);
    margin-bottom: 16px;
    border: 1px solid rgba(136, 192, 208, 0.2);
  }
  [data-theme="light"] .card-badge {
    background: rgba(94, 129, 172, 0.1);
    color: var(--primary);
    border: 1px solid rgba(94, 129, 172, 0.2);
  }
  
  .flow-visual-mockup {
    width: 240px;
    flex-shrink: 0;
    perspective: 800px;
  }
  .mock-popup {
    background: rgba(43, 48, 59, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    transform: rotateY(-12deg) rotateX(8deg);
