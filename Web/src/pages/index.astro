---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== HEADER ===== -->
  <header class="header">
    <div class="container nav-container">
      <a href="#" class="brand">
        <img src="/logo.png" alt="Qiko" class="logo-img" />
        <span class="font-display brand-name">Qiko</span>
      </a>

      <div class="nav-links">
        <a href="#features" class="nav-link font-display">Features</a>
        <a href="#security" class="nav-link font-display">Security</a>
        <a href="#faq" class="nav-link font-display">FAQ</a>
        <a href="#contact" class="nav-link font-display">Feedback</a>
      </div>

      <div class="nav-actions">
        <button id="theme-toggle" class="btn-toggle" title="Toggle theme">
          <span id="theme-icon" class="material-symbols-outlined">dark_mode</span>
        </button>
        <a href="https://chromewebstore.google.com" target="_blank" rel="noopener" class="btn btn-primary btn-sm">
          Get Extension
        </a>
      </div>
    </div>
  </header>

  <!-- ===== MAIN CONTENT ===== -->
  <main>
    <!-- HERO SECTION -->
    <section class="section hero hero-gradient">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="badge">
            <span class="pulse-dot"></span>
            Chrome Extension — Live Now
          </div>

          <h1 class="font-display hero-title">
            Pure Privacy.<br/>
            <span class="text-primary">Zero Friction.</span>
          </h1>

          <p class="hero-desc">
            Secure peer-to-peer messaging. Use this browser to chat instantly, or download our Chrome extension to stay connected in the flow. No servers, no footprints, no accounts.
          </p>

          <div class="hero-actions">
            <a href="/chat" class="btn btn-primary">
              Browser Chat
            </a>
            <a href="https://chromewebstore.google.com" target="_blank" rel="noopener" class="btn btn-outline">
              <span class="material-symbols-outlined" style="margin-right: 4px;">extension</span>
              Get the Extension
            </a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="glow-bg"></div>
          <img src="/logo.png" alt="Qiko Logo" class="hero-logo-img" />
        </div>
      </div>
    </section>

    <!-- FEATURES SECTION -->
    <section id="features" class="section features-sec">
      <div class="container">
        <div class="section-header">
          <div class="header-left">
            <h2 class="font-display section-title">Architected for Anonymity</h2>
            <p class="section-subtitle">
              We've stripped away everything between you and your conversations. No data collection, no storage, no compromises.
            </p>
          </div>
          <span class="header-right font-display text-primary">The Core Pillars</span>
        </div>

        <div class="features-grid">
          <!-- Large Card: Stay in Flow -->
          <div class="card card-pad feature-card-lg">
            <div class="card-copy">
              <div class="icon-chip bg-primary-light text-primary">
                <span class="material-symbols-outlined text-3xl">bolt</span>
              </div>
              <h3 class="font-display card-title">Stay in Your Flow</h3>
              <p class="card-desc">
                Forget heavy desktop apps or extra browser tabs. Qiko lives as a Chrome extension — click the icon, share your ID, and start a private session in seconds. No signups, no onboarding, zero friction.
              </p>
            </div>
            <div class="card-art">
              <span class="material-symbols-outlined art-icon">rocket_launch</span>
            </div>
          </div>

          <!-- Small Card: Absolute Anonymity -->
          <div class="card card-pad feature-card-sm">
            <div class="icon-chip bg-sec-light text-sec">
              <span class="material-symbols-outlined text-3xl">person_off</span>
            </div>
            <div>
              <h3 class="font-display card-title-sm">Absolute Anonymity</h3>
              <p class="card-desc-sm">
                Start instantly as a guest or create a persistent profile. Your session leaves no footprints — no email verification required for basic chatting.
              </p>
            </div>
          </div>

          <!-- Small Card: P2P Security -->
          <div class="card card-pad feature-card-sm">
            <div class="icon-chip bg-tert-light text-tert">
              <span class="material-symbols-outlined text-3xl">verified_user</span>
            </div>
            <div>
              <h3 class="font-display card-title-sm">Pure P2P Security</h3>
              <p class="card-desc-sm">
                Messages travel directly browser-to-browser. Your data never touches a database server because our P2P channel communicates end-to-end.
              </p>
            </div>
          </div>

          <!-- Mid Card: Stats Grid -->
          <div class="card card-pad feature-card-stats">
            <div class="stats-grid">
              <div class="stat-item">
                <span class="font-display stat-number text-primary">0%</span>
                <span class="stat-label">Server Storage</span>
              </div>
              <div class="stat-item">
                <span class="font-display stat-number text-primary">256-bit</span>
                <span class="stat-label">AES Encryption</span>
              </div>
              <div class="stat-item">
                <span class="font-display stat-number text-primary">Instant</span>
                <span class="stat-label">Peer Matching</span>
              </div>
              <div class="stat-item">
                <span class="font-display stat-number text-primary">Open</span>
                <span class="stat-label">Protocol Standards</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECURITY / TECHNICAL SECTION -->
    <section id="security" class="section security-sec">
      <div class="container security-grid">
        <div class="security-copy">
          <span class="pre-title font-display text-primary">Cryptography First</span>
          <h2 class="font-display section-title leading-tight">Clinical Security.<br/>Modern Interface.</h2>
          <p class="section-desc">
            Built on a Nord-inspired design philosophy: clean, precise, and distraction-free. High-security tools should feel like the future, not a legacy terminal.
          </p>
          <ul class="benefits-list">
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Firebase Realtime DB utilized solely for signaling
            </li>
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Identity metadata stored in secure local extension memory
            </li>
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Qiko IDs are ephemeral — delete anytime with zero residues
            </li>
            <li class="benefit-item">
              <span class="check-icon"><span class="material-symbols-outlined">check</span></span>
              Strict limit of 5 active connections to minimize footprint
            </li>
          </ul>
        </div>

        <div class="security-mockup">
          <div class="terminal terminal-shadow">
            <div class="terminal-header">
              <div class="window-controls">
                <span class="dot dot-close"></span>
                <span class="dot dot-minimize"></span>
                <span class="dot dot-expand"></span>
              </div>
              <span class="terminal-title">
                <span class="material-symbols-outlined">lock</span>
                secure-p2p-channel.qiko
              </span>
            </div>
            
            <div class="terminal-body">
              <div class="log-info">// Establishing P2P link...</div>
              
              <div class="message-row sent">
                <div class="message-bubble bubble-sent">
                  Initiating session. Encryption key verified.
                </div>
                <span class="timestamp">10:24 AM • Delivered</span>
              </div>

              <div class="message-row received">
                <div class="message-bubble bubble-received">
                  Connection stable. Peer hash: <span class="hash text-accent">#92x-K821-Q0</span>
                </div>
                <span class="timestamp">10:25 AM</span>
              </div>

              <div class="status-divider">
                <span class="status-chip">
                  <span class="material-symbols-outlined status-icon">verified_user</span>
                  Verified P2P Channel Active
                </span>
              </div>
            </div>

            <div class="terminal-input">
              <div class="input-placeholder">Type a secure message...</div>
              <button class="btn-send"><span class="material-symbols-outlined">send</span></button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section id="faq" class="section faq-sec">
      <div class="container faq-container">
        <h2 class="font-display section-title text-center">Common Questions</h2>
        
        <div class="faq-list">
          <details class="card faq-item">
            <summary class="faq-summary">
              Do I need to create an account?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              No. You can start as a guest immediately. Optionally add an email to create a persistent Qiko ID you can use across multiple devices.
            </div>
          </details>

          <details class="card faq-item">
            <summary class="faq-summary">
              Where are my messages stored?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              Messages are stored only in your local browser extension storage (chrome.storage.local). Your conversation history never touches our servers.
            </div>
          </details>

          <details class="card faq-item">
            <summary class="faq-summary">
              Who can message me?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              Only people you've added as a contact and who have your Qiko ID. You can have up to 5 connections active at any given time.
            </div>
          </details>

          <details class="card faq-item">
            <summary class="faq-summary">
              What is a Qiko ID?
              <span class="material-symbols-outlined faq-chevron">expand_more</span>
            </summary>
            <div class="faq-content">
              A short unique identifier (e.g. qx-abc123) generated when you set up the extension. Share it with someone you trust — they add it as a contact and you can start messaging.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- CONTACT / FEEDBACK SECTION -->
    <section id="contact" class="section contact-sec">
      <div class="container faq-container">
        <h2 class="font-display section-title text-center">Give Suggestions & Comments</h2>
        <p class="section-subtitle text-center" style="margin-bottom: 32px; max-width: 600px; margin-left: auto; margin-right: auto;">
          Have ideas, found a bug, or want to suggest new features? Send a secure transmission directly to the developer.
        </p>

        <div class="card card-pad contact-card">
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="contact-form">
            <input type="hidden" name="access_key" value="186c8161-07f7-4f99-9b38-ecef428bc717">
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" required class="form-input" placeholder="Your Name" />
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" required class="form-input" placeholder="your.email@example.com" />
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" required rows="4" class="form-input form-textarea" placeholder="Write your suggestions or comments here..."></textarea>
            </div>

            <button type="submit" id="submit-btn" class="btn btn-primary btn-submit">
              Send Feedback
            </button>
          </form>
        </div>
      </div>
    </section>

  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="container footer-container">
      <div class="footer-left">
        <img src="/logo.png" alt="Qiko" class="footer-logo" />
        <span class="font-display footer-brand">Qiko</span>
        <span class="footer-tagline">— Zero Friction P2P Chat</span>
      </div>
      <div class="footer-right">
        Chrome Extension · Built with ❤️ · No servers harmed
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* ===== CSS STYLES FOR LANDING PAGE ===== */
  
  /* Header */
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    border-bottom: 1px solid var(--border);
    background-color: var(--bg);
    transition: background-color var(--transition), border-color var(--transition);
  }
  .nav-container {
    display: flex;
    justify-content: justify;
    justify-content: space-between;
    align-items: center;
    height: 72px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .logo-img {
    height: 36px;
    width: 36px;
    object-fit: contain;
  }
  .brand-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.5px;
  }
  .nav-links {
    display: flex;
    gap: 40px;
    align-items: center;
  }
  .nav-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--muted);
    transition: color var(--transition);
  }
  .nav-link:hover {
    color: var(--primary);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .header .btn-primary.btn-sm {
    padding: 6px 14px;
    font-size: 0.8rem;
    border-radius: var(--radius-sm);
  }
  .btn-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    color: var(--primary);
    transition: background var(--transition);
  }
  .btn-toggle:hover {
    background: var(--bg-alt);
  }

  /* Hero Section */
  .hero {
    padding-top: clamp(4rem, 10vw, 9rem);
    padding-bottom: clamp(4rem, 10vw, 9rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: center;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
    background-color: color-mix(in srgb, var(--primary) 8%, transparent);
    color: var(--primary);
    margin-bottom: 24px;
  }
  .hero-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -2px;
    margin-bottom: 24px;
    color: var(--text);
  }
  .text-primary {
    color: var(--primary);
  }
  .hero-desc {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 520px;
    margin-bottom: 32px;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .glow-bg {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.15;
    background-color: var(--primary);
  }
  .hero-logo-img {
    position: relative;
    width: 240px;
    height: 240px;
    object-fit: contain;
    filter: drop-shadow(0 12px 36px rgba(var(--primary-rgb), 0.2));
    transition: transform var(--transition);
  }
  .hero-visual:hover .hero-logo-img {
    transform: scale(1.05);
  }
  .web-chat-section {
    margin-bottom: 20px;
  }
  .web-chat-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.85;
  }
  .extension-action {
    margin-top: 16px;
  }
  .btn-extension {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary);
    transition: opacity var(--transition);
  }
  .btn-extension:hover {
    opacity: 0.8;
  }
  .btn-extension .material-symbols-outlined {
    font-size: 1.125rem;
  }

  /* Features Section */
  .features-sec {
    background-color: var(--bg-alt);
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 24px;
  }
  .header-left {
    max-width: 600px;
  }
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 12px;
    color: var(--text);
  }
  .section-subtitle {
    font-size: 1.125rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .header-right {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 24px;
  }
  .feature-card-lg {
    grid-column: span 8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .card-copy {
    flex: 1;
  }
  .bg-primary-light {
    background-color: color-mix(in srgb, var(--primary) 12%, transparent);
  }
  .card-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
  }
  .card-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .card-art {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--primary) 6%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .art-icon {
    font-size: 5rem;
    color: var(--primary);
    opacity: 0.35;
  }

  .feature-card-sm {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
  }
  .bg-sec-light {
    background-color: color-mix(in srgb, var(--secondary) 12%, transparent);
  }
  .text-sec {
    color: var(--secondary);
  }
  .card-title-sm {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }
  .card-desc-sm {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .bg-tert-light {
    background-color: color-mix(in srgb, var(--tertiary) 12%, transparent);
  }
  .text-tert {
    color: var(--tertiary);
  }

  .feature-card-stats {
    grid-column: span 8;
    background: linear-gradient(135deg, var(--surface), color-mix(in srgb, var(--bg-alt) 70%, transparent));
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    width: 100%;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat-number {
    font-size: 2rem;
    font-weight: 800;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
  }

  /* Technical Section */
  .security-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 64px;
    align-items: center;
  }
  .pre-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    display: block;
  }
  .section-desc {
    font-size: 1.125rem;
    color: var(--muted);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .check-icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .check-icon .material-symbols-outlined {
    font-size: 0.875rem;
    font-weight: 800;
  }

  /* Mockup Terminal */
  .terminal {
    background-color: var(--terminal-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    font-family: monospace;
    font-size: 0.8125rem;
    color: #e5e9f0;
  }
  .terminal-header {
    background-color: var(--terminal-2);
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 15%, transparent);
  }
  .window-controls {
    display: flex;
    gap: 6px;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-close { background-color: #bf616a; }
  .dot-minimize { background-color: #ebcb8b; }
  .dot-expand { background-color: #a3be8c; }
  .terminal-title {
    font-size: 0.75rem;
    color: #4c566a;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .terminal-title .material-symbols-outlined {
    font-size: 0.875rem;
  }
  .terminal-body {
    padding: 24px;
    min-height: 260px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .log-info {
    color: #4c566a;
  }
  .message-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .message-row.sent {
    align-items: flex-end;
  }
  .message-row.received {
    align-items: flex-start;
  }
  .message-bubble {
    padding: 12px 16px;
    border-radius: var(--radius-md);
    max-width: 80%;
  }
  .bubble-sent {
    background-color: color-mix(in srgb, var(--primary) 25%, transparent);
    color: #88c0d0;
    border: 1px solid color-mix(in srgb, var(--primary) 35%, transparent);
    border-top-right-radius: 0;
  }
  .bubble-received {
    background-color: rgba(255, 255, 255, 0.05);
    color: #d8dee9;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top-left-radius: 0;
  }
  .text-accent {
    color: #88c0d0;
  }
  .timestamp {
    font-size: 0.6875rem;
    color: #4c566a;
  }
  .status-divider {
    border-top: 1px solid color-mix(in srgb, var(--border) 10%, transparent);
    padding-top: 16px;
    display: flex;
    justify-content: center;
  }
  .status-chip {
    display: inline-flex;
    align-items: center;
