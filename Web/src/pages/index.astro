  [data-theme="light"] .anon-circle.inner {
    background: rgba(94, 129, 172, 0.1);
    border-color: rgba(94, 129, 172, 0.3);
    color: var(--primary);
  }
  .anon-circle.inner .material-symbols-outlined {
    font-size: 1.1rem;
  }

  .p2p-card {
