---
import Layout from '../../layouts/Layout.astro';
import '../../styles/chat/style.css';
---

<Layout title="Qiko — Browser Chat">
  <div class="chat-page-wrapper" style="position: relative; overflow: hidden;">
    <div class="aurora-glow"></div>
    <div class="glass-panel welcome-container" style="max-width: 500px; width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 36px 24px; text-align: center; gap: 24px; position: relative; z-index: 2;">
        <div class="shield-graphic-container">
            <div class="shield-graphic-glow"></div>
            <div class="shield-image-box" style="width: 80px; height: 80px;">
                <img src="/logo.png" alt="Qiko Logo" class="shield-preview-img">
            </div>
        </div>

        <div class="welcome-title-group">
            <h1 class="welcome-title-upgraded">Qiko</h1>
            <p class="welcome-desc-upgraded">Secure & Private Browser Chat. Create or sign in with your Qiko ID to begin.</p>
        </div>

        <div class="welcome-actions-group" style="margin-top: 8px; width: 100%;">
            <button id="btn-create-id" class="btn-upgraded btn-primary-upgraded">
                <span class="material-symbols-outlined">fingerprint</span>
                Create Qiko ID
            </button>
            <button id="btn-sign-id" class="btn-upgraded btn-outline-upgraded">
                <span class="material-symbols-outlined">login</span>
                Sign with Qiko ID
            </button>
        </div>

        <!-- Upgraded Footer -->
        <footer class="welcome-footer-upgraded" style="border-top: 1px solid var(--color-border); margin-top: 12px; width: 100%; opacity: 0.85;">
            <div class="welcome-footer-left">
                <span>© Qiko 2026 • v0.1</span>
            </div>
            <div class="welcome-footer-right">
                <span class="welcome-encrypted-dot"></span>
                <span>P2P ENCRYPTED</span>
            </div>
        </footer>
    </div>
  </div>
</Layout>

<script>
  import '../../scripts/popup.js';
</script>

<style>
  .chat-page-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40px 24px;
    background-color: transparent !important;
    box-sizing: border-box;
  }
</style>
