---
import Layout from '../../layouts/Layout.astro';
import '../../styles/chat/style.css';
---

<Layout title="Qiko — Authentication">
  <div class="chat-page-wrapper">
    <!-- Screen: Loading/Connecting -->
    <div id="screen-loading" class="logins-container-upgraded hide">
        <div class="logins-content-scrollable" style="justify-content: center; align-items: center; gap: 24px;">
            <div class="spinner-logo pulse-spinner">
                <svg class="loading-logo-svg" width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" fill="var(--color-primary)" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9 11L11 13L15 9" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h2 id="loading-text" class="loading-title">Securing your connection...</h2>
        </div>
        <!-- Upgraded Footer -->
        <footer class="welcome-footer-upgraded" style="margin-top: auto;">
            <div class="welcome-footer-left">
                <span>© Qiko 2026 • v0.1</span>
            </div>
            <div class="welcome-footer-right">
                <span class="welcome-encrypted-dot"></span>
                <span>P2P ENCRYPTED</span>
            </div>
        </footer>
    </div>

    <!-- Screen: Profile & Qiko ID Setup -->
    <div id="screen-profile-setup" class="logins-container-upgraded hide">
        <div class="logins-header-upgraded">
            <h2 class="welcome-title-upgraded" style="font-size: 18px;">Setup Profile</h2>
            <span class="status-badge" style="margin: 0;">
                <span class="status-dot"></span> Connected
            </span>
        </div>

        <div class="logins-content-scrollable">
            <h3 class="setup-title" style="margin-top: 0; font-size: 14px; color: var(--color-muted-text); margin-bottom: 8px;">Your Qiko ID</h3>

            <!-- Frosted Glass ID Box -->
            <div class="id-display-glass">
                <input type="text" id="generated-id-input" class="id-input-glass" readonly value="qx-xxxx-xxxx-0">
                <button type="button" id="btn-copy-id" class="btn-copy-in" title="Copy Qiko ID" style="right: 8px; background: none; border: none;">
                    <span class="material-symbols-outlined" style="font-size: 18px; color: var(--color-primary);">content_copy</span>
                    <span id="copy-tooltip" class="copy-tooltip">Copy</span>
                </button>
            </div>

            <div class="inline-actions" style="margin-bottom: 20px; gap: 10px; display: flex;">
                <button type="button" id="btn-setup-back" class="btn-upgraded btn-outline-upgraded" style="height: 38px; font-size: 13px; flex: 1;">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back
                </button>
                <button type="button" id="btn-setup-skip" class="btn-upgraded btn-primary-upgraded" style="height: 38px; font-size: 13px; flex: 1;">
                    Continue
                    <span class="material-symbols-outlined">east</span>
                </button>
            </div>

            <!-- Glass Form Container -->
            <div class="glass-panel" style="margin-bottom: 8px;">
                <p class="setup-description" style="font-size: 12px; margin-top: 0; margin-bottom: 12px; color: var(--color-muted-text); font-weight: 500;">
                    Register to save connections and sync across devices:
                </p>

                <form id="form-profile-setup" class="setup-form-upgraded">
                    <div class="form-group">
                        <label for="setup-email">Email</label>
                        <input type="email" id="setup-email" class="form-control" placeholder="name@example.com" required>
                    </div>
                    <div class="form-group">
                        <label for="setup-password">Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" id="setup-password" class="form-control" placeholder="Min 6 characters" required minlength="6">
                            <button type="button" class="btn-toggle-password" data-target="setup-password" title="Toggle password visibility">
                                <svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="pointer-events: none;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            </button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="setup-username">Username (Optional)</label>
                        <input type="text" id="setup-username" class="form-control" placeholder="Nickname">
                    </div>

                    <span class="setup-disclaimer" style="margin-top: 4px;">Completing this form is optional, but signing out without registering will erase local data.</span>

                    <div id="setup-error-msg" class="error-text hide"></div>

                    <button type="submit" id="btn-register" class="btn-upgraded btn-primary-upgraded" style="height: 38px; font-size: 13px; margin-top: 4px;">
                        <span class="material-symbols-outlined">person_add</span>
                        Register Account
                    </button>
                </form>
            </div>
        </div>

        <!-- Upgraded Footer -->
        <footer class="welcome-footer-upgraded" style="margin-top: auto;">
            <div class="welcome-footer-left">
                <span>© Qiko 2026 • v0.1</span>
            </div>
            <div class="welcome-footer-right">
                <span class="welcome-encrypted-dot"></span>
                <span>P2P ENCRYPTED</span>
            </div>
        </footer>
    </div>

    <!-- Screen: Verification -->
    <div id="screen-verification" class="logins-container-upgraded hide">
        <div class="logins-header-upgraded">
            <h2 class="welcome-title-upgraded" style="font-size: 18px;">Verification</h2>
            <span class="status-badge" style="margin: 0;">
                <span class="status-dot"></span> Connected
            </span>
        </div>

        <div class="logins-content-scrollable">
            <div class="glass-panel" style="margin-top: 10px; margin-bottom: 8px;">
                <h3 class="setup-title" style="margin-top: 0; font-size: 15px;">Verify Your Email</h3>
                <p class="setup-description" style="font-size: 12.5px; line-height: 18px; color: var(--color-muted-text);">
                    We sent a verification email to:<br>
                    <strong id="sent-code-email" style="color: var(--color-primary); display: inline-block; margin: 8px 0; word-break: break-all;">email@example.com</strong>.<br>
                    Please check your inbox, click the activation link, and then click below.
                </p>

                <div id="verification-error-msg" class="error-text hide" style="margin-bottom: 12px;"></div>

                <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                    <button type="button" id="btn-verify-submit" class="btn-upgraded btn-primary-upgraded" style="height: 40px; font-size: 13px;">
                        <span class="material-symbols-outlined">verified</span>
                        I have verified my email
                    </button>
                    <button type="button" id="btn-resend-verification" class="btn-upgraded btn-outline-upgraded" style="height: 40px; font-size: 13px;">
                        <span class="material-symbols-outlined">send</span>
                        Resend verification email
                    </button>
                    <button type="button" id="btn-verification-back" class="btn-upgraded btn-outline-upgraded" style="height: 40px; font-size: 13px;">
                        <span class="material-symbols-outlined">arrow_back</span>
                        Back to Profile Setup
                    </button>
                </div>
            </div>
        </div>

        <!-- Upgraded Footer -->
        <footer class="welcome-footer-upgraded" style="margin-top: auto;">
            <div class="welcome-footer-left">
                <span>© Qiko 2026 • v0.1</span>
            </div>
            <div class="welcome-footer-right">
                <span class="welcome-encrypted-dot"></span>
                <span>P2P ENCRYPTED</span>
            </div>
        </footer>
    </div>

    <!-- Screen: Sign In -->
    <div id="screen-sign-in" class="logins-container-upgraded hide">
        <div class="logins-header-upgraded">
            <div style="display: flex; align-items: center; gap: 8px;">
                <button type="button" id="btn-back-to-start" class="btn-icon-back" title="Back" style="background: none; border: none; padding: 4px; cursor: pointer; color: var(--color-text); display: flex; align-items: center; justify-content: center; outline: none;">
                    <span class="material-symbols-outlined" style="font-size: 20px;">arrow_back</span>
                </button>
                <h2 class="welcome-title-upgraded" style="font-size: 18px;">Sign In</h2>
            </div>
            <span class="status-badge" style="margin: 0;">
                <span class="status-dot"></span> Connected
            </span>
        </div>

        <div class="logins-content-scrollable">
            <!-- Glass Form Container -->
            <div class="glass-panel" style="margin-top: 10px; margin-bottom: 8px;">
                <p class="setup-description" style="font-size: 12.5px; margin-top: 0; margin-bottom: 16px; color: var(--color-muted-text);">
                    Enter email and password to retrieve your Qiko ID and sync contacts:
                </p>

                <form id="form-sign-in" class="setup-form-upgraded">
                    <div class="form-group">
                        <label for="signin-email">Email</label>
                        <input type="email" id="signin-email" class="form-control" placeholder="name@example.com" required>
                    </div>
                    <div class="form-group">
                        <label for="signin-password">Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" id="signin-password" class="form-control" placeholder="Enter password" required>
                            <button type="button" class="btn-toggle-password" data-target="signin-password" title="Toggle password visibility">
                                <svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="pointer-events: none;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            </button>
                        </div>
                    </div>

                    <div id="signin-error-msg" class="error-text hide" style="margin-top: 4px;"></div>

                    <button type="submit" id="btn-signin-submit" class="btn-upgraded btn-primary-upgraded" style="height: 40px; font-size: 13px; margin-top: 8px;">
                        <span class="material-symbols-outlined">login</span>
                        Sign In
                    </button>
                </form>
            </div>
        </div>

        <!-- Upgraded Footer -->
        <footer class="welcome-footer-upgraded" style="margin-top: auto;">
            <div class="welcome-footer-left">
                <span>© Qiko 2026 • v0.1</span>
            </div>
            <div class="welcome-footer-right">
                <span class="welcome-encrypted-dot"></span>
                <span>P2P ENCRYPTED</span>
            </div>
        </footer>
    </div>
  </div>
</Layout>

<script>
  import '../../scripts/popup.js';
</script>

<style>
  .chat-page-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40px 24px;
    background-color: transparent !important;
    box-sizing: border-box;
  }
  .logins-container-upgraded {
    max-width: 500px !important;
    width: 100% !important;
    height: auto !important;
    min-height: 520px;
    background: rgba(255, 255, 255, 0.02) !important;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border) !important;
    border-radius: 20px !important;
    padding: 32px 28px !important;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--color-text) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15) !important;
  }
  [data-theme="light"] .logins-container-upgraded {
    background: rgba(255, 255, 255, 0.45) !important;
    box-shadow: 0 20px 50px rgba(94, 129, 172, 0.08) !important;
  }
</style>
