{
  "manifest_version": 3,
  "name": "Qiko",
  "version": "1.0.0",
  "description": "Send messages and URLs to your friends directly from your browser.",
  "author": "Mirza Iris - neuro94",
  "homepage_url": "https://mirza-iris.dev",
  "icons": {
    "16": "icons/icon128.png",
    "32": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/main.js",
    "scripts": ["lib/peerjs.min.js", "background/main.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "32": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "storage", "scripting", "identity", "identity.email", "offscreen", "notifications"]
}
